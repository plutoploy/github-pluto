# Plutoploy GH Bot Configuration

# Server port
PORT=8080

# Public base URL when behind a reverse proxy (no trailing slash).
# The webhook endpoint registered in GitHub becomes PUBLIC_URL/webhook
# e.g. https://gh.example.com
PUBLIC_URL=

# GitHub App credentials
APP_ID=your_github_app_id
WEBHOOK_SECRET=your_webhook_secret
# Path to the GitHub App private key PEM file (or the PEM contents directly)
PRIVATE_KEY=private-key.pem

# GitHub API base URL (for GitHub Enterprise)
# GITHUB_BASE_URL=https://api.github.com

# Smee.io webhook proxy URL (for local development)
# Get one at https://smee.io
# SMEE_URL=https://smee.io/your-channel-id
